generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // ✅ SEM url aqui — vai para o prisma.config.ts
}

model Tenant {
  id            String         @id @default(cuid())
  nome          String
  slug          String         @unique
  telefone      String
  ativo         Boolean        @default(true)
  criadoEm      DateTime       @default(now())
  servicos             String?
  mensagemLembrete     String?
  onboardingCompleted  Boolean  @default(false)
  profissionais Profissional[]
  clientes      Cliente[]
  agendamentos  Agendamento[]
}

model Profissional {
  id           String        @id @default(cuid())
  tenantId     String
  nome         String
  email        String
  telefone     String?
  role         String        @default("atendente")
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  agendamentos Agendamento[]
}

model Cliente {
  id           String        @id @default(cuid())
  tenantId     String
  nome         String
  telefone     String
  servicoPadrao String?
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  agendamentos Agendamento[]
}

model WhitelistEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  criadoEm  DateTime @default(now())
}

model Agendamento {
  id                 String       @id @default(cuid())
  tenantId           String
  clienteId          String
  profissionalId     String
  servico            String
  dataHora           DateTime
  status             String       @default("agendado")
  tokenConfirm       String       @unique @default(cuid())
  lembreteEnviadoEm  DateTime?
  criadoEm           DateTime     @default(now())
  tenant             Tenant       @relation(fields: [tenantId], references: [id])
  cliente            Cliente      @relation(fields: [clienteId], references: [id])
  profissional       Profissional @relation(fields: [profissionalId], references: [id])
}
